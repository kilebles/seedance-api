# BytePlus Seedance API
SEEDANCE_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com

# PostgreSQL — host=db when running via Docker Compose, localhost for local dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/seedance

# Fixed admin account (no registration yet)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Background worker poll interval (seconds)
WORKER_POLL_INTERVAL=10
